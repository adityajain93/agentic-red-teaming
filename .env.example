# Required for the local attacker/judge agents.
OPENAI_API_KEY=sk-...

# Modal CLI auth is created by `modal setup`.
# If you run non-interactively, Modal may also use:
# MODAL_TOKEN_ID=ak-...
# MODAL_TOKEN_SECRET=as-...

# Required when modal_vllm.py is deployed with proxy auth enabled.
# These are Modal Proxy Auth Token values, not the Modal CLI token above.
MODAL_PROXY_TOKEN_ID=wk-...
MODAL_PROXY_TOKEN_SECRET=ws-...

# Serving-side Modal/vLLM deploy-time config read by modal_vllm.py.
MODAL_APP_NAME=agentic-red-team-vllm
MODAL_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
MODAL_MODEL_REVISION=
MODAL_SERVED_MODEL_NAME=llm
MODAL_GPU=A10G
MODAL_TENSOR_PARALLEL_SIZE=1
MODAL_MAX_MODEL_LEN=4096
MODAL_GPU_MEMORY_UTILIZATION=0.90
MODAL_DTYPE=auto
MODAL_QUANTIZATION=
MODAL_TRUST_REMOTE_CODE=0
MODAL_EXTRA_VLLM_ARGS=
MODAL_REQUIRE_PROXY_AUTH=1
MODAL_VLLM_API_KEY=replace-with-your-vllm-api-key

# Optional client-side notes for external tools that call the deployed endpoint.
# This repo does not register Modal/vLLM as a red-team target.
# base_url: https://your-workspace--agentic-red-team-vllm-serve.modal.run/v1
# model: value of MODAL_SERVED_MODEL_NAME
# api_key: value of MODAL_VLLM_API_KEY, when configured

# Example model swaps:
# MODAL_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
# MODAL_MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct
# MODAL_MODEL_NAME=Qwen/Qwen2.5-14B-Instruct
# MODAL_GPU=L40S
# MODAL_GPU=H100
# MODAL_GPU=H100:2
# MODAL_TENSOR_PARALLEL_SIZE=2

# Optional for gated/private Hugging Face repos. Create this with:
# modal secret create hf-token HF_TOKEN=hf_...
# MODAL_HF_SECRET_NAME=hf-token
